                            [
                              {"name": "modid", "type": "string"},
                              {"name": "version", "type": "string"}
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      "name": "channels",
                      "type": [
                        "array",
                        {
                          "countType": "varint",
                          "type": [
                            "container",
                            [
                              {"name": "name", "type": "string"},
                              {"name": "marker", "type": "string"}
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      "name": "registries",
                      "type": [
                        "array",
                        {
                          "countType": "varint",
                          "type": [
                            "container",
                            [
                              {"name": "name", "type": "string"},
                              {"name": "marker", "type": "string"}
                            ]
                          ]
                        }
                      ]
                    }
